# Copy this file to .env and replace the placeholder before using Groq.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_DISCOVERY_MODEL=groq/compound-mini

# Local application settings
APP_HOST=127.0.0.1
APP_PORT=8000
CRAWL_MAX_PAGES=5
CRAWL_MAX_DEPTH=1
CRAWL_CONCURRENCY=3
CRAWL_TIMEOUT_MS=45000
VISION_MAX_IMAGES=5
CAPTURE_TIMEZONE=America/New_York
